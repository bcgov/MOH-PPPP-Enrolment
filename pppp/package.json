{
  "name": "pppp",
  "version": "2.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "serve": "vite preview --host",
    "test": "vitest",
    "test:unit": "vitest --coverage",
    "test:e2e": "start-server-and-test 'vite --host --port 5173' 5173 'cypress open --e2e --config baseUrl=http://localhost:5173/pppp/ --env environment=local'",
    "test:e2e:headless": "start-server-and-test 'vite --host --port 5173' 5173 'cypress run --browser chrome --config baseUrl=http://localhost:5173/pppp/ --env environment=local'",
    "test:e2e:dev": "cypress open --e2e --config baseUrl=http://dev.my.gov.bc.ca/pppp/ --env environment=dev",
    "test:e2e:test": "cypress open --e2e --config baseUrl=http://test.my.gov.bc.ca/pppp/ --env environment=test",
    "lint": "eslint .",
    "format": "prettier . --write",
    "prepare": "node bin/check-husky.mjs",
    "pre-commit": "lint-staged",
    "pre-commit:lint": "eslint",
    "pre-commit:prettier": "prettier --check --ignore-unknown"
  },
  "dependencies": {
    "@bcgov/bootstrap-v5-theme": "^1.0.1",
    "@fortawesome/vue-fontawesome": "^3.1.1",
    "@vuelidate/core": "^2.0.1",
    "@vuelidate/validators": "^2.0.0-alpha.29",
    "axios": "^1.16.1",
    "common-lib-vue": "^3.1.1-alpha.7",
    "date-fns": "^4.1.0",
    "uuid": "^14.0.0",
    "vue": "^3.5.34",
    "vue-router": "^4.0.15",
    "vuex": "^4.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/eslint-plugin": "^1.6.17",
    "@vue/test-utils": "^2.2.2",
    "cypress": "^15.15.0",
    "eslint": "^10.4.0",
    "eslint-plugin-compat": "^7.0.2",
    "eslint-plugin-cypress": "^6.4.1",
    "eslint-plugin-vue": "^10.9.1",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^17.0.4",
    "lodash": "^4.18.1",
    "prettier": "^3.8.3",
    "start-server-and-test": "^3.0.5",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
